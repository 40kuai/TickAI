# ======================================
# 🎫 TickAI Configuration Template
# ======================================
# Copy this file to .env and fill in your real values
# ======================================

# ======================================
# 🤖 TokenHub (LLM) - Required
# ======================================
# 腾讯云 MaaS TokenHub API Key
# Get this powers the Ask LLM page and AI features
TOKENHUB_API_KEY=your_tokenhub_api_key_here

# LLM Model to use
# Recommended: deepseek-v4-flash, deepseek-v3, etc.
TOKENHUB_MODEL=deepseek-v4-flash

# TokenHub Base URL
TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/plan/v3

# ======================================
# 💾 Database Configuration - Required
# ======================================
# SQLite database file path
OPS_DB_PATH=data/opsticket.db

# ======================================
# 🔐 LDAP Configuration - Optional
# ======================================
# Used by the ldap_search_user tool
# Leave commented if you don't need LDAP functionality
# ======================================

# LDAP server hostname or IP
# LDAP_SERVER=ldap.example.com

# LDAP port (389 for non-SSL, 636 for SSL
# LDAP_PORT=636

# Use SSL connection (true/false)
# LDAP_USE_SSL=true

# Bind DN for LDAP authentication
# LDAP_BIND_DN=CN=ldap_search_user,OU=Service Accounts,DC=example,DC=com

# Bind password
# LDAP_BIND_PASSWORD=your_ldap_password_here

# Search base DN for user queries
# LDAP_SEARCH_BASE=OU=Users,DC=example,DC=com

# ======================================
# 🚀 Service Configuration - Optional
# ======================================
# Streamlit server port (default: 8502)
# STREAMLIT_SERVER_PORT=8502

# ======================================
# 🔧 Advanced - Optional
# ======================================
# Debug mode (true/false)
# DEBUG=false
